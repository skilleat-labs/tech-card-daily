# 감테크 카드 자동화 환경변수
# .env.example → .env 복사 후 실제 값으로 교체

# Claude API (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Buffer API (https://buffer.com/developers/api)
BUFFER_ACCESS_TOKEN=1/...
BUFFER_PROFILE_IDS=instagram_profile_id,linkedin_profile_id

# 선택: 특정 시리즈 강제 지정 (k8s / docker / azure / aiml)
# 비우면 날짜 기반 자동 로테이션
SERIES_ID=
